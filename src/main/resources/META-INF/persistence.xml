    <!-- APP   -->
    <persistence-unit name="GESTIONALE-TRASPORTI-PUBBLICI">
        <!-- <class>giuliacrepaldi.entities.VenditaTrasporto</class>-->
        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/GESTIONALE-TRASPORTI-PUBBLICI"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
